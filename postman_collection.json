            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception Updated\",\n  \"director\": \"Christopher Nolan\",\n  \"description\": \"Updated description for this movie.\",\n  \"release_year\": 2010,\n  \"genre\": \"sci_fi\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/movies/{{movie_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "movies",
                "{{movie_id}}",
                ""
              ]
            }
          }
        },
