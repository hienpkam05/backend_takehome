            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Inception\",\n  \"director\": \"Christopher Nolan\",\n  \"description\": \"A movie about nested dreams and reality.\",\n  \"release_year\": 2010,\n  \"genre\": \"sci_fi\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/movies/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "movies",
                ""
              ]
            }
          }
        },
        {
          "name": "Retrieve Movie",
          "request": {
            "method": "GET",
            "header": [],
